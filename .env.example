# Canonical site URL used for metadata, Open Graph URLs, sitemap, and robots.txt.
NEXT_PUBLIC_SITE_URL=https://nestjs-ninja.com

# Required only when running `npm run covers:generate`.
OPENAI_API_KEY=

# Optional cover image generation settings.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_COVER_IMAGE_FILENAME=cover.png
